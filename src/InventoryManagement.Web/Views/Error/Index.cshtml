@{
    ViewData["Title"] = "Error";
}

<div class="text-center py-5">
    <h1 class="display-1 text-muted">500</h1>
    <h3>Something went wrong</h3>
    <p class="text-muted">An unexpected error occurred. Please try again later.</p>
    @if (ViewBag.RequestId != null)
    {
        <p class="text-muted small">Request ID: <code>@ViewBag.RequestId</code></p>
    }
    <a class="btn btn-primary" asp-controller="Dashboard" asp-action="Index"><i class="bi bi-house me-1"></i>Go to Dashboard</a>
</div>