@model InventoryManagement.Web.ViewModels.InventoryHistoryViewModel
@{
    ViewData["Title"] = "Inventory History";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h3 mb-1">Inventory History</h1>
        <p class="text-muted mb-0">View all stock movements.</p>
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-success" asp-action="StockIn"><i class="bi bi-plus-circle me-1"></i>Stock In</a>
        <a class="btn btn-warning" asp-action="StockOut"><i class="bi bi-dash-circle me-1"></i>Stock Out</a>
    </div>
</div>

<div class="card table-card mb-4">
    <div class="card-body">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-6">
                <label class="form-label">Filter by Product</label>
                <select name="productId" class="form-select" asp-items="@(new SelectList(Model.Products, "Value", "Text", Model.ProductId))">
                    <option value="">All Products</option>
                </select>
            </div>
            <div class="col-md-6 d-flex gap-2">
                <button type="submit" class="btn btn-outline-primary"><i class="bi bi-funnel"></i> Filter</button>
                <a asp-action="History" class="btn btn-outline-secondary">Clear</a>
            </div>
        </form>
    </div>
</div>

<div class="card table-card">
    <div class="table-responsive">
        <table class="table mb-0 align-middle">
            <thead class="table-light">
                <tr>
                    <th>Date</th>
                    <th>Product</th>
                    <th>Type</th>
                    <th class="text-end">Change</th>
                    <th>Notes</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Transactions.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted py-5">No inventory transactions recorded yet.</td>
                    </tr>
                }
                else
                {
                    foreach (var tx in Model.Transactions)
                    {
                        <tr>
                            <td>@tx.TransactionDate.ToString("yyyy-MM-dd HH:mm")</td>
                            <td>
                                <div class="fw-semibold">@tx.ProductName</div>
                                <div class="text-muted small">@tx.ProductSKU</div>
                            </td>
                            <td>
                                @if (tx.TransactionType == TransactionType.StockIn)
                                {
                                    <span class="badge bg-success">Stock In</span>
                                }
                                else if (tx.TransactionType == TransactionType.StockOut)
                                {
                                    <span class="badge bg-warning text-dark">Stock Out</span>
                                }
                                else
                                {
                                    <span class="badge bg-info text-dark">Adjustment</span>
                                }
                            </td>
                            <td class="text-end @(tx.QuantityChanged >= 0 ? "text-success" : "text-danger")">
                                @(tx.QuantityChanged > 0 ? "+" : string.Empty)@tx.QuantityChanged
                            </td>
                            <td class="text-muted">@tx.Notes</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>