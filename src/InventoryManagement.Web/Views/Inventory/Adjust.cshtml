@model InventoryManagement.Application.DTOs.InventoryTransactionDto
@{
    ViewData["Title"] = "Adjust Inventory";
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Inventory" asp-action="History">Inventory</a></li>
        <li class="breadcrumb-item active">Adjust</li>
    </ol>
</nav>

<div class="card table-card">
    <div class="card-header bg-white">
        <h5 class="mb-0">Adjust Inventory</h5>
    </div>
    <div class="card-body">
        <form asp-action="Adjust" method="post">
            <input type="hidden" asp-for="TransactionType" value="@TransactionType.Adjustment" />
            <input type="hidden" asp-for="ProductId" />
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">New Quantity</label>
                    <input asp-for="Quantity" type="number" min="0" class="form-control" />
                    <span asp-validation-for="Quantity" class="text-danger small"></span>
                </div>
                <div class="col-12">
                    <label asp-for="Notes" class="form-label"></label>
                    <textarea asp-for="Notes" class="form-control" rows="2"></textarea>
                </div>
            </div>
            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-info text-white"><i class="bi bi-sliders me-1"></i>Apply Adjustment</button>
                <a asp-action="History" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}